# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_database_password_here
DB_DATABASE=zky_cloud

# JWT 配置 (请使用强随机字符串)
JWT_SECRET=your_jwt_secret_key_here

# Redis 配置 (用于消息缓存)
REDIS_HOST=localhost
REDIS_PORT=6379

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=1073741824

# 前端地址 (CORS)
FRONTEND_URL=http://localhost:5173
