### 7. GSAP 动画示例

#### [NEW] `frontend/src/composables/useAnimations.ts`

```typescript
import { gsap } from 'gsap';

// 卡片入场动画
export function useCardEntrance(elements: HTMLElement[]) {
  gsap.fromTo(elements, 
    { opacity: 0, y: 50, scale: 0.95 },
    { 
      opacity: 1, 
      y: 0, 
      scale: 1,
      duration: 0.6,
      stagger: 0.1,
      ease: 'power3.out'
    }
  );
}

// 悬停发光效果
export function useGlowHover(element: HTMLElement) {
  element.addEventListener('mouseenter', () => {
    gsap.to(element, {
      boxShadow: '0 0 30px rgba(var(--accent-rgb), 0.4)',
      scale: 1.02,
      duration: 0.3
    });
  });
  
  element.addEventListener('mouseleave', () => {
    gsap.to(element, {
      boxShadow: '0 0 0px transparent',
      scale: 1,
      duration: 0.3
    });
  });
}
```

